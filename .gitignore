# Secrets (seed from USB)
data/secrets/hermes.env

# Optional local container image preloads (large artifacts, not source)
data/container-images/*.tar
data/container-images/*.tar.gz
data/container-images/*.oci

# Nix build artifacts
result
result-*

# hermes-agent source (bundled separately via setup-hermes-agent.sh)
hermes-agent-src/

# System state (lives on the target SSD, not USB)
var-lib-hermes/

# Boot image build outputs
boot-image/aports/
boot-image/rootfs/
boot-image/*.cpio.gz
boot-image/*.img
boot-image/*.iso
boot-image/*.tar.gz

# Local USB/recovery backups copied from removable media
usb-backup-*/

# Accidental root-level copy of boot-image/overlay/auto-deploy.sh
/auto-deploy.sh

# Build caches
.fuse_*
*.swp
*.swo
